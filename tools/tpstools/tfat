#!/bin/bash
# extfs helper for files with 512-byte header + FAT image

cmd="$1"
archive="$2"
shift 2

# Add @@512 to tell mtools to skip the header
archive_with_offset="${archive}@@512"

case "$cmd" in
    list)
        current_dir=""
        while IFS= read -r line; do
            # Remove carriage return and trim
            line=$(echo "$line" | sed 's/\r$//')
            trimmed=$(echo "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
            
            # Directory header
            if [[ "$trimmed" =~ ^Directory[[:space:]]+for[[:space:]]+::/(.*)$ ]]; then
                dir_path="${BASH_REMATCH[1]}"
                dir_path=$(echo "$dir_path" | sed 's|/$||')
                current_dir="$dir_path"
                continue
            fi
            
            # Skip empty lines and metadata
            [[ -z "$trimmed" ]] && continue
            [[ "$trimmed" =~ ^Volume ]] && continue
            [[ "$trimmed" =~ ^[[:space:]]*[0-9]+[[:space:]]+files ]] && continue
            [[ "$trimmed" =~ bytes[[:space:]]+free ]] && continue
            [[ "$trimmed" =~ ^Total[[:space:]]+files[[:space:]]+listed: ]] && continue
            
            # Skip . and .. entries (they appear as "<DIR>" lines)
            if [[ "$trimmed" =~ ^\.([[:space:]]|$) || "$trimmed" =~ ^\.\.([[:space:]]|$) ]]; then
                continue
            fi
            
            # Ensure line has a date (YYYY-MM-DD) and time
            if ! echo "$trimmed" | grep -qE '[0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[0-9]{2}:[0-9]{2}'; then
                continue
            fi
            
            # Directory entry
            if [[ "$line" =~ \<DIR\> ]]; then
                # Format: "bin          <DIR>      2026-03-11  15:44"
                # Extract directory name (everything before <DIR>)
                dirname=$(echo "$line" | sed 's/[[:space:]]*<DIR>.*//' | sed 's/[[:space:]]*$//')
                # Additional safety: skip if dirname is "." or ".." (should have been caught above, but double-check)
                [[ "$dirname" == "." || "$dirname" == ".." ]] && continue
                date=$(echo "$line" | awk '{print $(NF-1)}')
                time=$(echo "$line" | awk '{print $NF}')
                size=0
                perms="drwxr-xr-x"
                # Build full path with trailing slash
                if [[ -n "$current_dir" ]]; then
                    full_path="${current_dir}/${dirname}/"
                else
                    full_path="${dirname}/"
                fi
            else
                # File entry
                # Fields: size, date, time are last three
                size=$(echo "$line" | awk '{print $(NF-2)}')
                date=$(echo "$line" | awk '{print $(NF-1)}')
                time=$(echo "$line" | awk '{print $NF}')
                # Filename is everything before the last three fields
                filename=$(echo "$line" | awk '{
                    for(i=1; i<=NF-3; i++) {
                        printf "%s", $i
                        if(i<NF-3) printf " "
                    }
                }' | sed 's/[[:space:]]*$//')
                
                # Convert 8.3 names: if filename ends with space + 1-3 chars, replace space with dot
                if [[ "$filename" =~ [[:space:]]([^[:space:]]{1,3})$ ]]; then
                    display_filename=$(echo "$filename" | sed 's/ \([^ ]\{1,3\}\)$/.\1/')
                else
                    display_filename="$filename"
                fi
                
                perms="-rw-r--r--"
                # Build full path
                if [[ -n "$current_dir" ]]; then
                    full_path="${current_dir}/${display_filename}"
                else
                    full_path="$display_filename"
                fi
            fi
            
            # Convert date from YYYY-MM-DD to MM-DD-YYYY (spec requires this format)
            newdate=$(echo "$date" | awk -F- '{printf "%s-%s-%s", $2, $3, $1}')
            
            # Output in MC's required format
            echo "$perms 1 0 0 $size $newdate $time $full_path"
        done < <(mdir -i "$archive_with_offset" -/ :: 2>/dev/null)
        ;;
                
 copyout)
        src="$1"
        dest="$2"
        mcopy -i "$archive_with_offset" "::$src" "$dest"
        ;;
        
    copyin)
        dest="$1"
        src="$2"
        mcopy -i "$archive_with_offset" "$src" "::$dest"
        # mtools writes directly to the file with offset, no need to rebuild
        ;;
        
    rm)
        file="$1"
        mdel -i "$archive_with_offset" "$file"
        ;;
        
    mkdir)
        dir="$1"
        mmd -i "$archive_with_offset" "$dir"
        ;;
        
    rmdir)
        dir="$1"
        mrd -i "$archive_with_offset" "$dir"
        ;;
        
    *)
        exit 1
        ;;
esac

exit 0
